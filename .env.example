# ── Lavira Media Engine — Environment Template ──────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# Server port (web UI + REST API)
PORT=4005

# Storage paths (relative to project root, or absolute)
UPLOADS_DIR=./uploads
OUTPUTS_DIR=./outputs
ASSETS_DIR=./assets
DB_PATH=./lavira.db

# ── API Keys (all optional — engine degrades gracefully without them) ────────

# Anthropic Claude — AI caption + video script generation
ANTHROPIC_API_KEY=

# Pexels — stock photo/video search
PEXELS_API_KEY=

# GIPHY — GIF search + download
GIPHY_API_KEY=

# ── Social Publishing (optional) ────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
TIKTOK_ACCESS_TOKEN=
