# ── Lavira Safaris — Pre-filled API Keys for Zero-Touch Deployment ────────────
#
# HOW TO USE:
#   1. Copy this file to: keys.env  (same folder as setup-remote-access.ps1)
#   2. Fill in your values below
#   3. Run Install-Lavira.bat on the Windows machine
#
# The setup script reads keys.env silently and injects keys into .env
# automatically — no Notepad prompts, no user interaction required.
#
# SECURITY: Do not commit keys.env to git. It is already in .gitignore.
# Share it out-of-band (USB drive, private message, etc.) with the recipient.
# ─────────────────────────────────────────────────────────────────────────────

# Required — AI caption + script generation
# Get yours free at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — stock photo search (Pexels free tier is generous)
# Get yours at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional — GIF search
# Get yours at: https://developers.giphy.com/
GIPHY_API_KEY=

# Optional — social publishing (leave blank if not publishing directly)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
TIKTOK_ACCESS_TOKEN=

# Tailscale auth key — joins this Windows machine to the Lavira support network
# Required for remote support. Generate at: https://login.tailscale.com/admin/settings/keys
# Use: Reusable=Yes, Tags=tag:lavira, Expiry=90d
TS_AUTH_KEY=
